# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Env / local config
.env
.env.*
!.env.example
/wp-config.php
/wp-config-local.php
/wp-config-*.php
!/wp-config-sample.php

# Theme Eurohairlab bundled assets — keep tracked in git (do not add rules that ignore these paths):
#   wp-content/themes/eurohairlab/assets/fonts/
#   wp-content/themes/eurohairlab/assets/images/

# WordPress generated content
/wp-content/uploads/
/wp-content/blogs.dir/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/backups/
/wp-content/advanced-cache.php
/wp-content/object-cache.php
/wp-content/debug.log
/wp-content/wflogs/

# Dependencies / runtime artifacts
node_modules/
# Do not use bare `vendor/` — it ignores e.g. `wp-content/plugins/meta-box/vendor/` and breaks Meta Box activation (Composer autoload for `MetaBox\…`).
/vendor/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Archives / temporary files
*.zip
*.tar
*.gz
*.log
*.tmp
*.swp
